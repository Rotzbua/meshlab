<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX installer for MeshLab.

  Required wix build variables:
    Version=<MeshLab version, e.g. 2222.11>
    SourceDir=<path to the deployed MeshLab directory>
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="MeshLab $(var.Version)"
           Language="1033"
           Version="$(var.Version)"
           Manufacturer="Paolo Cignoni - VCG - ISTI - CNR"
           UpgradeCode="F170F615-6173-440E-9D24-E76C00996727"
           InstallerVersion="500"
           Scope="perMachine"
           Compressed="yes">

    <SummaryInformation Description="MeshLab $(var.Version) Installer"
                        Manufacturer="Paolo Cignoni - VCG - ISTI - CNR" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />

    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <Icon Id="MeshLabIcon" SourceFile="$(var.SourceDir)\meshlab.exe" />
    <Property Id="ARPPRODUCTICON" Value="MeshLabIcon" />
    <Property Id="ARPHELPLINK" Value="https://www.meshlab.net" />
    <Property Id="ARPURLINFOABOUT" Value="https://www.meshlab.net" />
    <Property Id="ARPNOREPAIR" Value="yes" />

    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="$(var.SourceDir)\LICENSE.rtf" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="VCGDir" Name="VCG">
        <Directory Id="INSTALLFOLDER" Name="MeshLab" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="MeshLabMenuDir" Name="MeshLab">
        <Component Id="StartMenuShortcut" Guid="045D8910-1AE5-4146-A883-C74760676D9B">
          <Shortcut Id="StartMenuSC"
                    Name="MeshLab"
                    Target="[INSTALLFOLDER]meshlab.exe"
                    WorkingDirectory="INSTALLFOLDER"
                    Icon="MeshLabIcon"
                    IconIndex="0" />
          <RemoveFolder Id="MeshLabMenuDirRemove" On="uninstall" />
          <RegistryValue Root="HKCU"
                         Key="Software\VCG\MeshLab"
                         Name="StartMenuInstalled"
                         Type="integer"
                         Value="1"
                         KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder">
      <Component Id="DesktopShortcut" Guid="E8C440AE-685C-46C2-B86F-B817D62921C4">
        <Shortcut Id="DesktopSC"
                  Name="MeshLab"
                  Target="[INSTALLFOLDER]meshlab.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="MeshLabIcon"
                  IconIndex="0" />
        <RegistryValue Root="HKCU"
                       Key="Software\VCG\MeshLab"
                       Name="DesktopInstalled"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="AppPathsRegistry" Guid="46A25D1C-327B-4504-81DB-D6BB86C70D6B">
        <RegistryKey Root="HKLM"
                     Key="Software\Microsoft\Windows\CurrentVersion\App Paths\meshlab.exe">
          <RegistryValue Type="string"
                         Value="[INSTALLFOLDER]meshlab.exe"
                         KeyPath="yes" />
          <RegistryValue Name="Path" Type="string" Value="[INSTALLFOLDER]" />
        </RegistryKey>
      </Component>
    </DirectoryRef>

    <CustomAction Id="RunVcRedist"
                  BinaryRef="Wix4UtilCA_X64"
                  DllEntry="WixQuietExec64"
                  Execute="deferred"
                  Return="ignore"
                  Impersonate="no" />

    <SetProperty Id="RunVcRedist"
                 Value="&quot;[INSTALLFOLDER]vc_redist.x64.exe&quot; /q /norestart"
                 Before="RunVcRedist"
                 Sequence="execute" />

    <InstallExecuteSequence>
      <Custom Action="RunVcRedist" After="InstallFiles" Condition="NOT Installed" />
    </InstallExecuteSequence>

    <Feature Id="ProductFeature" Title="MeshLab" Level="1">
      <ComponentGroupRef Id="MeshLabFiles" />
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentRef Id="DesktopShortcut" />
      <ComponentRef Id="AppPathsRegistry" />
    </Feature>

  </Package>

  <Fragment>
    <ComponentGroup Id="MeshLabFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.SourceDir)\**">
        <Exclude Files="$(var.SourceDir)\LICENSE.rtf" />
      </Files>
    </ComponentGroup>
  </Fragment>
</Wix>
